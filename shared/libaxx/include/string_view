#ifndef LIBAXX_STRING_VIEW
#define LIBAXX_STRING_VIEW

#include <assert.h>
#include <stddef.h>

namespace std {

class string_view {
 public:
  // Types

  using char_type = char;
  using value_type = char_type;
  using size_type = size_t;
  using const_pointer = const value_type*;
  using const_reference = const value_type&;
  using const_iterator = const value_type*;

  // Constructors

  constexpr string_view() = default;
  constexpr string_view(const string_view& other) = default;
  // Constructs a view of the first "count" characters in the string
  constexpr string_view(const char* string, size_type count)
      : m_data(string), m_length(count) {
    assert(m_length <= strlen(string));
  }
  /* Constructs a view of all the characters in the string, not including the
   * terminating null character */
  constexpr string_view(const char* string) {
    m_data = string;
    m_length = strlen(string);
  }

  /* A string view cannot be constructed from a nullptr according to the C++
   * standard (from C++ 23 and onwards) */
  constexpr string_view(decltype(nullptr)) = delete;

  // Methods

  constexpr const_pointer data() const { return m_data; }
  constexpr size_type length() const { return m_length; }
  constexpr bool empty() const { return length() == 0; }

  // Accessing or iterating on elements of a string_view is always read-only

  constexpr const_iterator begin() const { return data(); }
  constexpr const_iterator cbegin() const { return data(); }
  constexpr const_iterator end() const { return data() + length(); }
  constexpr const_iterator cend() const { return data() + length(); }

  constexpr const_reference operator[](size_type index) const {
    assert(index < length());
    return *(data() + index);
  }

  /* Copies "count" characters of the string_view, starting from the character
   * at "position", into the "destination" character array. Returns the number
   * of copied characters. */
  constexpr size_type copy(char_type* destination, size_type count,
                           size_type position = 0) const {
    size_type i = 0;
    while ((i + position < count) && (i + position < length())) {
      *(destination + i) = m_data[i + position];
      i++;
    }
    return i;
  }

 private:
  // Redefinition of strlen here to avoid creating a dependency to liba
  constexpr size_t strlen(const char* s) {
    const char* str = s;
    while (*str) str++;
    return str - s;
  }

  const_pointer m_data = nullptr;
  size_type m_length = 0;
};

// String equality operator
constexpr bool operator==(std::string_view view1, std::string_view view2) {
  if (view1.length() != view2.length()) {
    return false;
  }
  for (size_t i = 0; i < view1.length(); i++) {
    if (view1[i] != view2[i]) {
      return false;
    }
  }
  return true;
}

}  // namespace std

#endif
